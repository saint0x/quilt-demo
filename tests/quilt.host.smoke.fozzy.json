{
  "version": 1,
  "name": "quilt-host-smoke",
  "steps": [
    {
      "type": "proc_when",
      "cmd": "bash",
      "args": [
        "-lc",
        "unset QUILT_API_KEY QUILT_TOKEN; ../quilt/quilt.sh list >/dev/null 2>/dev/null"
      ],
      "exit_code": 1,
      "stdout": "",
      "stderr": "",
      "times": 1
    },
    {
      "type": "proc_spawn",
      "cmd": "bash",
      "args": [
        "-lc",
        "unset QUILT_API_KEY QUILT_TOKEN; ../quilt/quilt.sh list >/dev/null 2>/dev/null"
      ],
      "expect_exit": 1
